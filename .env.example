# ─── Aether Weather — Environment Variables ───────────────────────────────────
# Copy this file to .env.local and fill in your values.
# The app works perfectly with NO API keys — it uses Open-Meteo (free, no auth).
# Optional integrations below enhance the experience.

# ── Optional: OpenWeatherMap (for air quality + more) ──────────────────────────
# NEXT_PUBLIC_OWM_KEY=your_openweathermap_key_here
# Get one free at: https://openweathermap.org/api

# ── Optional: Mapbox (for mini map / radar feature) ───────────────────────────
# NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
# Get one free at: https://mapbox.com

# ── Optional: Override the default location on first load ─────────────────────
# NEXT_PUBLIC_DEFAULT_LAT=51.5074
# NEXT_PUBLIC_DEFAULT_LON=-0.1278
# NEXT_PUBLIC_DEFAULT_CITY=London

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Aether
NEXT_PUBLIC_APP_VERSION=1.0.0
